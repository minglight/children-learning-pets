<?xml version="1.0" encoding="UTF-8"?>
<!--
  課8「兩位數加減 · 直式計算」題庫
  數字題建議加上 <唸>,讓朗讀更自然(例:三十二加四,等於多少?)。

  ★ 直式圖(可省略)★
    <圖 種類="直式"/>
      → 系統自動讀 <問> 裡的兩個數字和「加 / 減」,排成直式給小朋友看。
      (例:<問>32 + 4 = ?</問> 會排成 32 在上、4 在下的直式。)
-->
<題庫 單元="兩位數加減">

  <題目>
    <問>32 + 4 = ?</問>
    <唸>三十二 加 四,等於多少?</唸>
    <圖 種類="直式"/>
    <選項 答案="是">36</選項>
    <選項>38</選項>
    <選項>35</選項>
  </題目>

  <題目>
    <問>35 + 13 = ?</問>
    <唸>三十五 加 十三,等於多少?</唸>
    <圖 種類="直式"/>
    <選項 答案="是">48</選項>
    <選項>47</選項>
    <選項>45</選項>
  </題目>

  <題目>
    <問>40 + 26 = ?</問>
    <唸>四十 加 二十六,等於多少?</唸>
    <圖 種類="直式"/>
    <選項 答案="是">66</選項>
    <選項>64</選項>
    <選項>76</選項>
  </題目>

  <題目>
    <問>51 + 23 = ?</問>
    <唸>五十一 加 二十三,等於多少?</唸>
    <圖 種類="直式"/>
    <選項 答案="是">74</選項>
    <選項>72</選項>
    <選項>64</選項>
  </題目>

  <題目>
    <問>47 − 5 = ?</問>
    <唸>四十七 減 五,等於多少?</唸>
    <圖 種類="直式"/>
    <選項 答案="是">42</選項>
    <選項>43</選項>
    <選項>41</選項>
  </題目>

  <題目>
    <問>68 − 24 = ?</問>
    <唸>六十八 減 二十四,等於多少?</唸>
    <圖 種類="直式"/>
    <選項 答案="是">44</選項>
    <選項>46</選項>
    <選項>42</選項>
  </題目>

  <題目>
    <問>99 − 33 = ?</問>
    <唸>九十九 減 三十三,等於多少?</唸>
    <圖 種類="直式"/>
    <選項 答案="是">66</選項>
    <選項>63</選項>
    <選項>69</選項>
  </題目>

  <題目>
    <問>5 + 53 = ?</問>
    <唸>五 加 五十三,等於多少?</唸>
    <選項 答案="是">58</選項>
    <選項>53</選項>
    <選項>63</選項>
  </題目>

  <題目>
    <問>23 + 5 = ?</問>
    <唸>二十三 加 五,等於多少?</唸>
    <選項 答案="是">28</選項>
    <選項>27</選項>
    <選項>29</選項>
  </題目>

  <題目>
    <問>30 + 30 = ?</問>
    <唸>三十 加 三十,等於多少?</唸>
    <選項 答案="是">60</選項>
    <選項>50</選項>
    <選項>70</選項>
  </題目>

  <題目>
    <問>56 − 6 = ?</問>
    <唸>五十六 減 六,等於多少?</唸>
    <選項 答案="是">50</選項>
    <選項>40</選項>
    <選項>52</選項>
  </題目>

  <題目>
    <問>62 + 14 = ?</問>
    <唸>六十二 加 十四,等於多少?</唸>
    <圖 種類="直式"/>
    <選項 答案="是">76</選項>
    <選項>74</選項>
    <選項>66</選項>
  </題目>

</題庫>
