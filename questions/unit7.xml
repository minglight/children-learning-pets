<!--
  課7「看月曆 · 日期星期」題庫
  改題方法和課6相同:<問> 為題目,3 個 <選項>,正確的加 答案="是"。

  ★ 月曆圖(可省略)★
    <圖 種類="月曆" 月="6" 圈="19" 星期="五"/>
      → 畫出 6 月的月曆,把 19 日圈起來。
      「星期」是告訴系統「被圈的那天是星期幾」,月曆才會排對位置
      (例:6 月 19 日是星期五,就寫 星期="五")。
    只想顯示整個月、不圈任何一天 → 把 圈 拿掉或寫 圈="0"。
-->
<題庫 單元="看月曆">

  <題目>
    <問>月曆上圈起來的是 6 月 19 日星期五,那 6 月 20 日是星期幾?</問>
    <唸>六月十九日是星期五,六月二十日是星期幾?</唸>
    <圖 種類="月曆" 月="6" 圈="19" 星期="五"/>
    <選項 答案="是">星期六</選項>
    <選項>星期四</選項>
    <選項>星期日</選項>
  </題目>

  <題目>
    <問>畢業典禮圈在 6 月 13 日,再過一個星期是 6 月幾日?</問>
    <唸>六月十三日,再過一個星期是六月幾日?</唸>
    <圖 種類="月曆" 月="6" 圈="13" 星期="六"/>
    <選項 答案="是">20 日</選項>
    <選項>19 日</選項>
    <選項>14 日</選項>
  </題目>

  <題目>
    <問>看月曆,6 月 19 日是星期五,下一個星期五是 6 月幾日?</問>
    <唸>六月十九日是星期五,下一個星期五是幾日?</唸>
    <圖 種類="月曆" 月="6" 圈="19" 星期="五"/>
    <選項 答案="是">26 日</選項>
    <選項>25 日</選項>
    <選項>20 日</選項>
  </題目>

  <題目>
    <問>看看 6 月的月曆,6 月一共有幾天?</問>
    <唸>六月一共有幾天?</唸>
    <圖 種類="月曆" 月="6" 圈="0"/>
    <選項 答案="是">30 天</選項>
    <選項>31 天</選項>
    <選項>29 天</選項>
  </題目>

  <題目>
    <問>月曆上圈的是 6 月 23 日,前一天是 6 月幾日?</問>
    <唸>六月二十三日的前一天是幾日?</唸>
    <圖 種類="月曆" 月="6" 圈="23" 星期="二"/>
    <選項 答案="是">22 日</選項>
    <選項>24 日</選項>
    <選項>21 日</選項>
  </題目>

  <題目>
    <問>一個星期有幾天?</問>
    <選項 答案="是">7 天</選項>
    <選項>5 天</選項>
    <選項>6 天</選項>
  </題目>

  <題目>
    <問>星期三的後一天是星期幾?</問>
    <選項 答案="是">星期四</選項>
    <選項>星期二</選項>
    <選項>星期五</選項>
  </題目>

  <題目>
    <問>今天是星期日,3 天後是星期幾?</問>
    <選項 答案="是">星期三</選項>
    <選項>星期二</選項>
    <選項>星期四</選項>
  </題目>

  <題目>
    <問>莎莎生日是 6 月 23 日,端午節是 6 月 19 日,哪一個先到?</問>
    <選項 答案="是">端午節</選項>
    <選項>莎莎生日</選項>
    <選項>同一天</選項>
  </題目>

  <題目>
    <問>一天有幾個小時?</問>
