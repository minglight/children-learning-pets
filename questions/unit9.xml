<?xml version="1.0" encoding="UTF-8"?>
<!--
  課9「分類整理 · 數一數比一比」題庫
  題目描述數量,讓小朋友比多少、算總數。

  ★ 圖案(可省略)★
    分類圖:用 <圖 種類="分類"> 裡面放幾組 <組>:
      <圖 種類="分類">
        <組 圖案="車" 顏色="紅" 數量="7"/>
        <組 圖案="車" 顏色="藍" 數量="8"/>
      </圖>
      圖案可填:車、圓、三角、長方、方、星
      顏色可填:紅、藍、黃、綠、紫、橘、粉
    數數圖:<圖 種類="數數" 內容="6, 3"/>(畫 6 個 + 3 個水果,系統隨機選水果)
    圖案都會 10 個一排,超過自動換行。
-->
<題庫 單元="分類整理">

  <題目>
    <問>紅色的車有 7 輛,藍色的車有 8 輛,哪一種比較多?</問>
    <唸>紅色的車和藍色的車,哪一種比較多?</唸>
    <圖 種類="分類">
      <組 圖案="車" 顏色="紅" 數量="7"/>
      <組 圖案="車" 顏色="藍" 數量="8"/>
    </圖>
    <選項 答案="是">藍色</選項>
    <選項>紅色</選項>
    <選項>一樣多</選項>
  </題目>

  <題目>
    <問>三角形有 5 個,圓形有 6 個,哪一種比較少?</問>
    <唸>三角形和圓形,哪一種比較少?</唸>
    <圖 種類="分類">
      <組 圖案="三角" 顏色="綠" 數量="5"/>
      <組 圖案="圓" 顏色="藍" 數量="6"/>
    </圖>
    <選項 答案="是">三角形</選項>
    <選項>圓形</選項>
    <選項>一樣多</選項>
  </題目>

  <題目>
    <問>長方形有 10 個,正方形有 3 個,長方形比正方形多幾個?</問>
    <唸>長方形比正方形多幾個?</唸>
    <圖 種類="分類">
      <組 圖案="長方" 顏色="紫" 數量="10"/>
      <組 圖案="方" 顏色="黃" 數量="3"/>
    </圖>
    <選項 答案="是">7 個</選項>
    <選項>13 個</選項>
    <選項>3 個</選項>
  </題目>

  <題目>
    <問>數數看,一共有幾個水果?</問>
    <唸>六個加三個,一共有幾個水果?</唸>
    <圖 種類="數數" 內容="6, 3"/>
    <選項 答案="是">9 個</選項>
    <選項>8 個</選項>
    <選項>10 個</選項>
  </題目>

  <題目>
    <問>三角形 5 個、正方形 3 個,一共有幾個圖形?</問>
    <唸>三角形五個加正方形三個,一共幾個?</唸>
    <圖 種類="分類">
      <組 圖案="三角" 顏色="綠" 數量="5"/>
      <組 圖案="方" 顏色="橘" 數量="3"/>
    </圖>
    <選項 答案="是">8 個</選項>
    <選項>9 個</選項>
    <選項>7 個</選項>
  </題目>

  <題目>
    <問>看圖,哪一種顏色的車最多?</問>
    <唸>哪一種顏色的車最多?</唸>
    <圖 種類="分類">
      <組 圖案="車" 顏色="黃" 數量="10"/>
      <組 圖案="車" 顏色="紅" 數量="7"/>
      <組 圖案="車" 顏色="藍" 數量="8"/>
    </圖>
    <選項 答案="是">黃色</選項>
    <選項>藍色</選項>
    <選項>紅色</選項>
  </題目>

  <題目>
    <問>黃色 10 個、紅色 7 個、藍色 8 個,哪一種顏色最少?</問>
    <選項 答案="是">紅色</選項>
    <選項>藍色</選項>
    <選項>黃色</選項>
  </題目>

  <題目>
    <問>玩套圈圈,小貓套中 3 次,小狗套中 5 次,誰套中比較多次?</問>
    <選項 答案="是">小狗</選項>
    <選項>小貓</選項>
    <選項>一樣多</選項>
  </題目>

  <題目>
    <問>射飛鏢,紅色 2 枝、藍色 3 枝、黃色 1 枝,哪一種顏色最多?</問>
    <選項 答案="是">藍色</選項>
    <選項>紅色</選項>
    <選項>黃色</選項>
  </題目>

  <題目>
    <問>紅色 7 輛、黃色 10 輛、藍色 8 輛,一共有幾輛車?</問>
    <選項 答案="是">25 輛</選項>
    <選項>24 輛</選項>
    <選項>26 輛</選項>
  </題目>

  <題目>
    <問>圓形有 6 個,正方形有 3 個,圓形比正方形多幾個?</問>
    <選項 答案="是">3 個</選項>
    <選項>9 個</選項>
    <選項>2 個</選項>
  </題目>

  <題目>
    <問>玩套圈圈,套中 5 次,沒套中 3 次,一共丟了幾次?</問>
    <選項 答案="是">8 次</選項>
    <選項>5 次</選項>
    <選項>2 次</選項>
  </題目>

</題庫>
