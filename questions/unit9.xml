<!--
  課9「分類整理 · 數一數比一比」題庫
  題目描述數量,讓小朋友比多少、算總數。

  ★ 圖案(可省略)★
    分類圖:用 <圖 種類="分類"> 裡面放幾組 <組>:
      <圖 種類="分類">
        <組 圖案="車" 顏色="紅" 數量="7"/>
        <組 圖案="車" 顏色="藍" 數量="8"/>
      </圖>
      圖案可填:車、圓、三角、長方、方、星
      顏色可填:紅、藍、黃、綠、紫、橘、粉
    數數圖:<圖 種類="數數" 內容="6, 3"/>(畫 6 個 + 3 個水果,系統隨機選水果)
    圖案都會 10 個一排,超過自動換行。
-->
<題庫 單元="分類整理">

  <題目>
    <問>紅色的車有 7 輛,藍色的車有 8 輛,哪一種比較多?</問>
    <唸>紅色的車和藍色的車,哪一種比較多?</唸>
    <圖 種類="分類">
      <組 圖案="車" 顏色="紅" 數量="7"/>
      <組 圖案="車" 顏色="藍" 數量="8"/>
    </圖>
    <選項 答案="是">藍色</選項>
    <選項>紅色</選項>
    <選項>一樣多</選項>
  </題目>

