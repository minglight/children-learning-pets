<?xml version="1.0" encoding="UTF-8"?>
<!--
  ╔══════════════════════════════════════════════════════════╗
  ║  課6「買東西 · 認識錢」題庫                                ║
  ║                                                            ║
  ║  老師 / 家長可以自由增加、修改題目:                       ║
  ║   • 一題 = 一組 <題目> … </題目>                           ║
  ║   • <問>   是題目文字(會顯示也會被朗讀)                  ║
  ║   • <選項> 是答案卡,每題放 3 個                            ║
  ║   • 正確的那個 <選項> 加上  答案="是"                       ║
  ║   • <唸>(可省略)另外指定朗讀文字,沒寫就唸 <問>          ║
  ║                                                            ║
  ║  ★ 加圖案(可省略,想要圖才加)★                          ║
  ║   錢幣圖:<圖 種類="錢" 內容="10x5, 1x3"/>                 ║
  ║          → 畫 5 個 10 元 + 3 個 1 元(面額只有 1,5,10,50) ║
  ║          也可寫 <圖 種類="錢" 金額="48"/> 讓系統自動湊。   ║
  ║   錢幣會 10 個一排,超過自動換行。                          ║
  ║  存檔後重新整理頁面即可生效,系統會隨機抽題。              ║
  ╚══════════════════════════════════════════════════════════╝
-->
<題庫 單元="買東西">

  <題目>
    <問>下面的錢加起來是多少元?</問>
    <唸>五個十元加三個一元,一共多少元?</唸>
    <圖 種類="錢" 內容="10x5, 1x3"/>
    <選項 答案="是">53 元</選項>
    <選項>35 元</選項>
    <選項>8 元</選項>
  </題目>

  <題目>
    <問>3 個 10 元加 4 個 5 元,一共是多少元?</問>
    <唸>三個十元加四個五元,一共多少元?</唸>
    <圖 種類="錢" 內容="10x3, 5x4"/>
    <選項 答案="是">50 元</選項>
    <選項>70 元</選項>
    <選項>34 元</選項>
  </題目>

  <題目>
    <問>一個 50 元加 2 個 10 元,一共是多少元?</問>
    <唸>一個五十元加兩個十元,一共多少元?</唸>
    <圖 種類="錢" 內容="50x1, 10x2"/>
    <選項 答案="是">70 元</選項>
    <選項>52 元</選項>
    <選項>60 元</選項>
  </題目>

  <題目>
    <問>下面的錢加起來是多少元?</問>
    <唸>四個十元、一個五元、三個一元,一共多少元?</唸>
    <圖 種類="錢" 內容="10x4, 5x1, 1x3"/>
    <選項 答案="是">48 元</選項>
    <選項>44 元</選項>
    <選項>38 元</選項>
  </題目>

  <題目>
    <問>妙妙有 4 個 10 元,一共是多少元?</問>
    <圖 種類="錢" 內容="10x4"/>
    <選項 答案="是">40 元</選項>
    <選項>14 元</選項>
    <選項>4 元</選項>
  </題目>

  <題目>
    <問>圖中的錢可以買 46 元的漢堡嗎?還差多少元?</問>
    <唸>四個十元,要買四十六元的漢堡,還差多少?</唸>
    <圖 種類="錢" 內容="10x4"/>
    <選項 答案="是">差 6 元</選項>
    <選項>剛好夠</選項>
    <選項>差 10 元</選項>
  </題目>

  <題目>
    <問>付了下面這些錢買 32 元的蛋糕,要找回多少元?</問>
    <唸>一個五十元,買三十二元的蛋糕,找回多少?</唸>
    <圖 種類="錢" 金額="50"/>
    <選項 答案="是">18 元</選項>
    <選項>22 元</選項>
    <選項>12 元</選項>
  </題目>

  <題目>
    <問>蛋糕 32 元、果汁 25 元,買這兩樣一共多少元?</問>
    <選項 答案="是">57 元</選項>
    <選項>47 元</選項>
    <選項>55 元</選項>
  </題目>

  <題目>
    <問>綠茶 18 元,付一個 50 元,要找回多少元?</問>
    <選項 答案="是">32 元</選項>
    <選項>38 元</選項>
    <選項>22 元</選項>
  </題目>

  <題目>
    <問>妙妙只有 40 元,下面哪一種點心買不起?</問>
    <選項 答案="是">漢堡 46 元</選項>
    <選項>綠茶 18 元</選項>
    <選項>果汁 25 元</選項>
  </題目>

  <題目>
    <問>蛋糕 32 元、漢堡 46 元,哪一個比較貴?</問>
    <選項 答案="是">漢堡</選項>
    <選項>蛋糕</選項>
    <選項>一樣貴</選項>
  </題目>

  <題目>
    <問>你有 50 元,買了一個 32 元的蛋糕,還剩多少元?</問>
    <選項 答案="是">18 元</選項>
    <選項>22 元</選項>
    <選項>12 元</選項>
  </題目>

  <題目>
    <問>7 個 10 元,一共是多少元?</問>
    <圖 種類="錢" 內容="10x7"/>
    <選項 答案="是">70 元</選項>
    <選項>17 元</選項>
    <選項>7 元</選項>
  </題目>

</題庫>
